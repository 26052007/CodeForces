#include <bits/stdc++.h>
using namespace std;
 
int main(){
 
    int t;
    cin>>t;
    while(t--){
 
        int n;
        cin>>n;
        int m = n-2;
 
        int b[m];
        for(int i = 0; i < m ; i++){
            cin>>b[i];
        }
 
        int flag = 0;
        for (int i = 0; i <= m - 3; ++i) {
            if (b[i] == 1 && b[i + 1] == 0 && b[i + 2] == 1) {
                flag++;
                break;
            }
        }
 
        if(flag != 0){
            cout << "NO" << endl;
        }
        else{
            cout << "YES" << endl;
        }
 
 
 
    }
 
 
}